---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts, getCategoriesWithCount } from "../../utils";

const posts = await getPublishedPosts();
const categories = getCategoriesWithCount(posts);
---

<BaseLayout
  title="Categories"
  description="Browse posts by category"
  canonicalURL={new URL("/categories/", Astro.site).href}
>
  <h1>Categories</h1>
  <p>{categories.length} categor{categories.length !== 1 ? "ies" : "y"}</p>

  {
    categories.length === 0 && (
      <p>No categories yet.</p>
    )
  }

  <div class="tag-cloud">
    {categories.map(({ category, count }) => (
      <a class="tag" href={`/categories/${category}`}>
        {category} ({count})
      </a>
    ))}
  </div>
</BaseLayout>
