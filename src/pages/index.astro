---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import Slider from "../components/Slider.astro";
import { getPublishedPosts, getTagsWithCount } from "../utils";

const base = import.meta.env.BASE_URL;
const posts = await getPublishedPosts();
const latestPosts = posts.slice(0, 5);
const tags = getTagsWithCount(posts);

const sliderImages = [
  { src: `${base}images/slider/1-snp-founding.jpeg`, alt: "SNP 组织创立", caption: "SNP 组织应运而生 — 思想先驱与技术美食大家的跨界火花" },
  { src: `${base}images/slider/2-snp-meeting.jpeg`, alt: "2026 首次会晤", caption: "「双堡会」— KFC 到麦当劳的思想与实践互补之道" },
  { src: `${base}images/slider/3-snp-feast.jpeg`, alt: "新成员 OW 加入", caption: "新成员 OW 正式加入 — 鸡族跨国团圆宴" },
];
---

<BaseLayout>
  <section class="intro">
    <Slider images={sliderImages} />
  </section>

  <!-- Latest Posts -->
  <section>
    <h2 class="section-title">Latest Posts</h2>
    {
      latestPosts.length === 0 && (
        <p>No posts yet. <a href={`${base}blog`}>View all posts</a>.</p>
      )
    }
    {latestPosts.map((post) => <PostCard post={post} />)}
    {posts.length > 5 && (
      <p style="margin-top: 1rem;">
        <a href={`${base}blog`}>View all {posts.length} posts &rarr;</a>
      </p>
    )}
  </section>

  <!-- Tags -->
  {
    tags.length > 0 && (
      <section>
        <h2 class="section-title">Tags</h2>
        <div class="tag-cloud">
          {tags.map(({ tag, count }) => (
            <a class="tag" href={`${base}tags/${tag}`}>{tag} ({count})</a>
          ))}
        </div>
        <p style="margin-top: 0.5rem;">
          <a href={`${base}tags`}>Browse all tags &rarr;</a>
        </p>
      </section>
    )
  }

  <!-- Archive link -->
  <section>
    <h2 class="section-title">Archive</h2>
    <p>
      <a href={`${base}archive`}>Browse the archive by year and month &rarr;</a>
    </p>
  </section>

  <!-- RSS -->
  <section>
    <h2 class="section-title">Subscribe</h2>
    <p>
      <a href={`${base}rss.xml`}>RSS Feed</a>
    </p>
  </section>
</BaseLayout>
