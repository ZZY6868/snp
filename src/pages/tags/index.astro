---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts, getTagsWithCount } from "../../utils";

const posts = await getPublishedPosts();
const tags = getTagsWithCount(posts);
---

<BaseLayout
  title="Tags"
  description="Browse posts by tag"
  canonicalURL={new URL("/tags/", Astro.site).href}
>
  <h1>Tags</h1>
  <p>{tags.length} tag{tags.length !== 1 ? "s" : ""}</p>

  {
    tags.length === 0 && (
      <p>No tags yet.</p>
    )
  }

  <div class="tag-cloud">
    {tags.map(({ tag, count }) => (
      <a class="tag" href={`/tags/${tag}`}>
        {tag} ({count})
      </a>
    ))}
  </div>
</BaseLayout>
