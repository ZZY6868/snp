---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getPublishedPosts, getTagsWithCount, filterPostsByTag } from "../../utils";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = getTagsWithCount(posts);
  return tags.map(({ tag }) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.params;
const allPosts = await getPublishedPosts();
const posts = filterPostsByTag(allPosts, tag!);
---

<BaseLayout
  title={`Tag: ${tag}`}
  description={`Posts tagged with "${tag}"`}
  canonicalURL={new URL(`/tags/${tag}`, Astro.site).href}
>
  <h1>Tag: {tag}</h1>
  <p>{posts.length} post{posts.length !== 1 ? "s" : ""}</p>

  {posts.map((post) => <PostCard post={post} />)}

  <p style="margin-top: 2rem;">
    <a href="/tags">&larr; All tags</a>
  </p>
</BaseLayout>
