---
import { SITE_CONFIG } from "../site.config";

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const navItems = [
  { href: `${base}`, label: "Home" },
  { href: `${base}blog`, label: "Blog" },
  { href: `${base}tags`, label: "Tags" },
  { href: `${base}archive`, label: "Archive" },
];

function isActive(href: string): boolean {
  if (href === base || href === `${base}`) return currentPath === base || currentPath === `${base}`;
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <a class="skip-link" href="#main-content">Skip to content</a>
  <div class="container">
    <a class="site-title" href={import.meta.env.BASE_URL}>{SITE_CONFIG.title}</a>
    <nav class="site-nav" aria-label="Main navigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[{ active: isActive(item.href) }]}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
